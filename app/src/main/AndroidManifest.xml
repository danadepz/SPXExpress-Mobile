<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.spx.express">

    <!-- 1. Internet Permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 2. Allow Network Security Config for XAMPP Loopback -->
    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="SPX Express"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SPXExpress"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="true">
        
        <!-- 3. Primary Launcher Activity -->
        <activity
            android:name=".ui.LandingActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.LoginActivity"
            android:exported="false" />

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false" />

        <!-- 4. Secondary Web App Shell Activity -->
        <activity
            android:name=".ui.WebViewActivity"
            android:exported="false" />

        <!-- 5. Native Role Dashboard & Operations Activities -->
        <activity
            android:name=".ui.admin.AdminDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.branch_manager.BranchManagerDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.staff.StaffDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.customer.CustomerDashboardActivity"
            android:exported="false" />
        <activity
            android:name=".ui.customer.BookParcelActivity"
            android:exported="false" />
        <activity
            android:name=".ui.customer.tracking.TrackingActivity"
            android:exported="false" />
        <activity
            android:name=".ui.rider.RiderDashboardActivity"
            android:exported="false" />
    </application>

</manifest>
