<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:layout_marginHorizontal="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Header: Tracking Number + Timestamp -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp">

            <TextView
                android:id="@+id/tvLogTrackingNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:textColor="#EE4D2D"
                android:text="DDX-XXXXXXXXX" />

            <TextView
                android:id="@+id/tvLogTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:textSize="12sp"
                android:textColor="#64748B"
                android:text="00:00 AM · Date" />
        </RelativeLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginBottom="12dp" />

        <!-- Middle Body: Activity Status Pill & Remarks -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <!-- Dynamic themed status badge -->
            <TextView
                android:id="@+id/tvLogStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_status_chip"
                android:text="Status" />

            <!-- Compact snippet of the remarks -->
            <TextView
                android:id="@+id/tvLogRemarkSnippet"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textSize="13sp"
                android:textColor="#475569"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Remarks..." />
        </LinearLayout>

        <!-- Relational Details Row: Personnel + Source Branch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginBottom="10dp">

            <!-- Personnel info container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Personnel"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#94A3B8" />

                <TextView
                    android:id="@+id/tvLogPersonnel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#334155"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="System Auto" />
            </LinearLayout>

            <!-- Source Branch container -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏢 Source Branch"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#94A3B8" />

                <TextView
                    android:id="@+id/tvLogBranch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#334155"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="Automated Hub" />
            </LinearLayout>
        </LinearLayout>

        <!-- View Details Action Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewLogDetails"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Check Details"
            android:textColor="#EE4D2D"
            android:textSize="12sp"
            android:textStyle="bold"
            app:rippleColor="#FFECE9" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
