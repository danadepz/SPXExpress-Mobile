<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Scan Waybill Barcode"
        android:textColor="#1E293B"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Scanner Mockup Visual Area -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="#0F172A"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/spx_express"
            android:alpha="0.1"
            android:scaleType="centerInside" />

        <!-- Mock barcode graphic -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Lines representing a barcode -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="||| | ||| || ||| || ||| | |||"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[Camera Barcode Scanner Mode Active]"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Red laser scanning line overlay -->
        <View
            android:id="@+id/vScannerLaser"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#EF4444"
            android:layout_alignParentTop="true" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manual Barcode Input"
        android:textColor="#475569"
        android:textSize="13sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Tracking Number"
        android:layout_marginBottom="16dp"
        app:boxStrokeColor="#DD6B20"
        app:hintTextColor="#DD6B20">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBarcode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textCapCharacters"
            android:text="DDX-" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelScan"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Close"
            android:textColor="#64748B"
            app:strokeColor="#CBD5E1"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerifyReceive"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:backgroundTint="#DD6B20"
            android:text="Verify &amp; Receive"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>
