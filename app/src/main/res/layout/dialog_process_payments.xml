<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💰 Financial Settlement"
        android:textColor="#1E293B"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify counter cash collections and online payment references."
        android:textColor="#64748B"
        android:textSize="12sp"
        android:layout_marginBottom="16dp" />

    <!-- Scrollable list of pending payments -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPendingPayments"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:scrollbars="vertical"
        android:layout_marginBottom="16dp" />

    <!-- Empty State View -->
    <LinearLayout
        android:id="@+id/llEmptyPayments"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="#CBD5E1"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Clear!"
            android:textColor="#475569"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No pending payments require verification."
            android:textColor="#94A3B8"
            android:textSize="12sp"
            android:gravity="center" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClosePayments"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Dismiss"
        android:textColor="#64748B"
        app:cornerRadius="10dp" />

</LinearLayout>
