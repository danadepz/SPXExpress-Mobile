<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".ui.rider.RiderDashboardActivity">

    <!-- MAIN CONTENT CONTAINER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Navigation Header -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent">
            <include layout="@layout/toolbar_welcome_header" />
        </androidx.appcompat.widget.Toolbar>

        <!-- Top Rider Stats Banner -->
        <LinearLayout
            android:id="@+id/riderStatsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="2"
            android:elevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <!-- Stat Card 1: Active Runs -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvActiveRuns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#EE4D2D" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Shipments"
                        android:textSize="11sp"
                        android:textColor="#64748B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stat Card 2: Completed -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvCompletedRuns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#10B981" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Delivered Today"
                        android:textSize="11sp"
                        android:textColor="#64748B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Fragment container to host fragments programmatically -->
        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/riderStatsLayout" />

        <!-- Profile Settings Form Container (Initially Hidden) -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/settingsFormContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"
            android:fillViewport="true"
            android:background="#F8FAFC"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Inner Card for Outlined Forms -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="0dp"
                    app:cardBackgroundColor="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Edit Profile"
                            android:textColor="#1E293B"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Update your rider profile natively"
                            android:textColor="#64748B"
                            android:textSize="13sp"
                            android:layout_marginBottom="24dp" />

                        <!-- First Name -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="First Name"
                            android:layout_marginBottom="16dp"
                            app:boxStrokeColor="#EE4D2D"
                            app:hintTextColor="#EE4D2D">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRiderFname"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Last Name -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Last Name"
                            android:layout_marginBottom="16dp"
                            app:boxStrokeColor="#EE4D2D"
                            app:hintTextColor="#EE4D2D">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRiderLname"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Email -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Email Address"
                            android:layout_marginBottom="16dp"
                            app:boxStrokeColor="#EE4D2D"
                            app:hintTextColor="#EE4D2D">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRiderEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Phone -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Contact Number (11 Digits)"
                            android:layout_marginBottom="16dp"
                            app:boxStrokeColor="#EE4D2D"
                            app:hintTextColor="#EE4D2D">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRiderPhone"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="phone"
                                android:maxLength="11" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Reset Password -->
                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Reset Password (Optional)"
                            android:layout_marginBottom="24dp"
                            app:boxStrokeColor="#EE4D2D"
                            app:hintTextColor="#EE4D2D"
                            app:passwordToggleEnabled="true"
                            app:placeholderText="Leave blank to keep current">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRiderPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Action Buttons -->
                        <Button
                            android:id="@+id/btnSaveRiderProfile"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:backgroundTint="#EE4D2D"
                            android:text="Save Profile Changes"
                            android:textColor="#FFFFFF"
                            android:textStyle="bold"
                            app:cornerRadius="12dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT SLIDING DRAWER SIDEBAR -->
    <LinearLayout
        android:id="@+id/rightDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:elevation="16dp">

        <!-- User profile details header (Dark Slate color styling) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1E293B"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Avatar -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/spx_express"
                    android:padding="6dp"
                    android:scaleType="centerInside" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvDrawerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Delivery Rider"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDrawerEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="rider@spx.com"
                android:textColor="#FFCDCD"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Navigation Menu Item Rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Item 1: Active Route Manifest -->
            <TextView
                android:id="@+id/navManifest"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="📦 Parcels Assigned"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

            <!-- Item 2: Cash Remittances -->
            <TextView
                android:id="@+id/navRemit"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="💰 Cash Remittance"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

            <!-- Item 3: Delivery History -->
            <TextView
                android:id="@+id/navHistory"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="📋 Delivery History"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

            <!-- Item 3: Edit Profile -->
            <TextView
                android:id="@+id/navEditProfile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="⚙️ Edit Profile"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- Divider & Logout Bottom Actions -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0" />

        <Button
            android:id="@+id/btnDrawerSignOut"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:text="Sign Out Rider"
            android:textColor="#EE4D2D"
            app:strokeColor="#EE4D2D"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
