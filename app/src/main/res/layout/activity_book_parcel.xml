<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Top Navigation Header -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FFFFFF"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="parent"
        app:title="Book New Shipment" />

    <!-- Horizontal Step Indicator Bubble Banner -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStepIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center"
            android:weightSum="4">

            <!-- Step 1 Bubble -->
            <LinearLayout
                android:id="@+id/indicatorStep1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvStep1Bubble"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_status_badge"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Drop-off"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textColor="#EE4D2D"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Step 2 Bubble -->
            <LinearLayout
                android:id="@+id/indicatorStep2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvStep2Bubble"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_status_badge"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Parcel"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textColor="#64748B" />
            </LinearLayout>

            <!-- Step 3 Bubble -->
            <LinearLayout
                android:id="@+id/indicatorStep3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvStep3Bubble"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_status_badge"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recipient"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textColor="#64748B" />
            </LinearLayout>

            <!-- Step 4 Bubble -->
            <LinearLayout
                android:id="@+id/indicatorStep4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:id="@+id/tvStep4Bubble"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_status_badge"
                    android:text="4"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="12sp"
                    android:gravity="center" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Confirm"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:textColor="#64748B" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Scrollable content hosting toggled step panels -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/btnSubmitLayout"
        app:layout_constraintTop_toBottomOf="@id/cardStepIndicator">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- STEP 1 PANEL: DROP-OFF POINT -->
            <LinearLayout
                android:id="@+id/layoutStepDropoff"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1. Origin Drop-off Branch Hub"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Please select which of our physical branches you will drop off this package at for processing:"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginBottom="16dp" />

                <!-- Drop-off outlet dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Drop-off Branch Hub"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="24dp">
                    <AutoCompleteTextView
                        android:id="@+id/spDropoffBranch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- STEP 2 PANEL: PARCEL METRICS & COST CALCULATOR -->
            <LinearLayout
                android:id="@+id/layoutStepParcel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2. Weight &amp; Payment Options"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Declared Weight (Kg) -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Parcel Weight (Kg)"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etWeight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Payment MethodDropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Payment Method"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="16dp">
                    <AutoCompleteTextView
                        android:id="@+id/spPaymentMethod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- COD Declared Value (Only visible when COD selected) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutDeclaredVal"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Declared Item Value / COD (₱)"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCod"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Payment Reference Number (Only visible when GCash or Maya selected) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutPaymentRef"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Transaction Reference Number"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    app:helperText="GCash: 13 digits · Maya: 12 digits"
                    app:helperTextEnabled="true"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPaymentRef"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:maxLines="1"
                        android:maxLength="13" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Real-time Cost Breakdown Panel -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:background="#F8FAFC">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Estimated Fees Summary"
                            android:textStyle="bold"
                            android:textColor="#475569"
                            android:textSize="13sp" />
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Shipping Fee:"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvShippingFeeVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₱0.00"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                        </RelativeLayout>
                        <RelativeLayout
                            android:id="@+id/rlTotalCollectRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:visibility="gone">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Amount to Collect:"
                                android:textColor="#EE4D2D"
                                android:textStyle="bold"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvTotalCollectVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₱0.00"
                                android:textStyle="bold"
                                android:textColor="#EE4D2D" />
                        </RelativeLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- STEP 3 PANEL: RECIPIENT INFORMATION & FILTERS -->
            <LinearLayout
                android:id="@+id/layoutStepRecipient"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3. Recipient Information"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Name (First and Last) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:hint="Receiver First Name"
                        app:boxStrokeColor="#EE4D2D"
                        app:hintTextColor="#EE4D2D">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReceiverFname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="Receiver Last Name"
                        app:boxStrokeColor="#EE4D2D"
                        app:hintTextColor="#EE4D2D">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etReceiverLname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <!-- Phone -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Contact Number (09xxxxxxxxx)"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etReceiverPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Street -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Street Address (Building/House No/Street)"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etReceiverStreet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Province Dropdown -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Select Province"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="12dp">
                    <AutoCompleteTextView
                        android:id="@+id/spReceiverProvince"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- City & Barangay Dropdowns -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:hint="Select City"
                        app:boxStrokeColor="#EE4D2D"
                        app:hintTextColor="#EE4D2D">
                        <AutoCompleteTextView
                            android:id="@+id/spReceiverCity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:hint="Select Barangay"
                        app:boxStrokeColor="#EE4D2D"
                        app:hintTextColor="#EE4D2D">
                        <AutoCompleteTextView
                            android:id="@+id/spReceiverBarangay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Postal code (Auto-filled) -->
                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Postal / Zip Code"
                    app:boxStrokeColor="#EE4D2D"
                    app:hintTextColor="#EE4D2D"
                    android:layout_marginBottom="16dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etReceiverPostal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:focusable="false"
                        android:clickable="false" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

            <!-- STEP 4 PANEL: CONFIRM & BOOKING SUMMARY -->
            <LinearLayout
                android:id="@+id/layoutStepPayment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4. Summary &amp; Confirmation"
                    android:textColor="#1E293B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- Detailed review card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E2E8F0"
                    android:layout_marginBottom="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shipment Review"
                            android:textStyle="bold"
                            android:textColor="#1E293B"
                            android:textSize="15sp"
                            android:layout_marginBottom="12dp" />

                        <!-- Origin details -->
                        <TextView
                            android:id="@+id/tvSummaryOrigin"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="🏢 Drop-off Hub: --"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <!-- Destination details -->
                        <TextView
                            android:id="@+id/tvSummaryDest"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="📍 Delivery Target: --"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <!-- Recipient details -->
                        <TextView
                            android:id="@+id/tvSummaryReceiver"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="👤 Recipient Name: --"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <!-- Weight details -->
                        <TextView
                            android:id="@+id/tvSummaryWeight"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="⚖️ Declared Weight: -- kg"
                            android:textColor="#475569"
                            android:textSize="13sp"
                            android:layout_marginBottom="6dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E2E8F0"
                            android:layout_marginVertical="12dp" />

                        <!-- Financial breakdown -->
                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Shipping Fee:"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvSummaryShippingVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₱0.00"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/rlSummaryCod"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:visibility="gone">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Declared Item Price:"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvSummaryCodVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₱0.00"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Payment Method:"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvSummaryMethod"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="--"
                                android:textStyle="bold"
                                android:textColor="#1E293B" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Payment Status:"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvSummaryPaymentStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="Pending Verification"
                                android:textStyle="bold"
                                android:textColor="#F59E0B" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/rlSummaryTotalCollect"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:visibility="gone">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total Amount to Collect:"
                                android:textColor="#EE4D2D"
                                android:textStyle="bold"
                                android:textSize="14sp" />
                            <TextView
                                android:id="@+id/tvSummaryTotalVal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="₱0.00"
                                android:textStyle="bold"
                                android:textColor="#EE4D2D"
                                android:textSize="14sp" />
                        </RelativeLayout>

                        <!-- Reference number preview row (visible for GCash/Maya only) -->
                        <RelativeLayout
                            android:id="@+id/rlSummaryRefNo"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:visibility="gone">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reference No.:"
                                android:textColor="#64748B"
                                android:textSize="13sp" />
                            <TextView
                                android:id="@+id/tvSummaryRefNo"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:text="--"
                                android:fontFamily="monospace"
                                android:textStyle="bold"
                                android:textColor="#1E293B"
                                android:textSize="13sp" />
                        </RelativeLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </RelativeLayout>
    </ScrollView>

    <!-- Footer Back and Next Buttons panel -->
    <LinearLayout
        android:id="@+id/btnSubmitLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:padding="16dp"
        android:elevation="8dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBackStep"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Back"
            android:textColor="#64748B"
            app:strokeColor="#CBD5E1"
            app:cornerRadius="16dp"
            android:visibility="invisible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextStep"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#EE4D2D"
            android:text="Next"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="16dp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
