<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvDispatchTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Dispatch Cargo Parcel"
        android:textColor="#1E293B"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Routing info card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#E2E8F0">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="#F8FAFC">

            <TextView
                android:id="@+id/tvParcelTrackingNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tracking No: DDX-XXXXXXXXXXXX"
                android:textStyle="bold"
                android:textColor="#DD6B20"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvParcelWeight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Parcel Weight: -- kg"
                android:textColor="#475569"
                android:textSize="13sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E2E8F0"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvRoutingPath"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Route: [Current] ➔ [Hub] ➔ [Final Destination]"
                android:textColor="#475569"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvRoutingType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dispatch Mode: Transfer to Hub"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:textSize="13sp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Dispatch Rider"
        android:textColor="#475569"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp" />

    <!-- Rider selection spinner layout -->
    <Spinner
        android:id="@+id/spRiders"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="16dp"
        android:background="@android:drawable/btn_dropdown"
        android:spinnerMode="dropdown" />

    <!-- Warning Block for Weight limit -->
    <LinearLayout
        android:id="@+id/llWeightWarningBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="#FEF2F2"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⚠️ Heavy Cargo Warning: This parcel exceeds the 10kg standard weight limit. Supervisor override is required to assign this shipment."
                android:textColor="#991B1B"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/swSupervisorOverride"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Authorize Supervisor Override"
            android:textColor="#1E293B"
            android:textSize="14sp"
            app:thumbTint="#DD6B20"
            app:trackTint="#FBD38D" />
    </LinearLayout>

    <!-- CTAs -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:weightSum="2">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelDispatch"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Cancel"
            android:textColor="#64748B"
            app:strokeColor="#CBD5E1"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCompleteDispatch"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:backgroundTint="#DD6B20"
            android:text="Complete"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>
