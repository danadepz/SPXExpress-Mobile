<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvDialogTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add New Branch"
        android:textColor="#1E293B"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <!-- Branch Name -->
    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Branch Name"
        android:layout_marginBottom="12dp"
        app:boxStrokeColor="#EE4D2D"
        app:hintTextColor="#EE4D2D">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etBranchName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Branch City -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/inputLayoutBranchCity"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="City"
        android:layout_marginBottom="12dp"
        app:boxStrokeColor="#EE4D2D"
        app:hintTextColor="#EE4D2D">
        <AutoCompleteTextView
            android:id="@+id/spBranchCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Branch Type -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Branch Type"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#CBD5E1"
        app:cardBackgroundColor="#F8FAFC">
        <Spinner
            android:id="@+id/spBranchType"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Branch Manager Assignment (Only for Creating Branches) -->
    <TextView
        android:id="@+id/tvBranchManagerLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assign Branch Manager"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardBranchManager"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#CBD5E1"
        app:cardBackgroundColor="#F8FAFC">
        <Spinner
            android:id="@+id/spBranchManager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="12dp" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="8dp"
            android:backgroundTint="#EE4D2D"
            android:text="Save Branch"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDelete"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="8dp"
            android:text="Delete Hub"
            android:textColor="#DC2626"
            android:visibility="gone"
            app:strokeColor="#DC2626"
            app:cornerRadius="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Cancel"
            android:textColor="#64748B"
            app:strokeColor="#CBD5E1"
            app:cornerRadius="10dp" />
    </LinearLayout>

</LinearLayout>
