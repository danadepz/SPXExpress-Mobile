<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC"
    tools:context=".ui.branch_manager.BranchManagerDashboardActivity">

    <!-- MAIN CONTENT CONTAINER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top Navigation Header -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:background="#FFFFFF"
            android:elevation="4dp"
            app:layout_constraintTop_toTopOf="parent">
            <include layout="@layout/toolbar_welcome_header" />
        </androidx.appcompat.widget.Toolbar>

        <!-- Stats Banner -->
        <LinearLayout
            android:id="@+id/managerStatsLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:padding="16dp"
            android:weightSum="2"
            android:elevation="2dp"
            app:layout_constraintTop_toBottomOf="@id/toolbar">

            <!-- Stat Card 1: Inventory -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvInventoryCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#E53E3E" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Active Inventory"
                        android:textSize="11sp"
                        android:textColor="#64748B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Stat Card 2: Cash Pending -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#F1F5F9">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvRemittanceCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="#10B981" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Verify Remittances"
                        android:textSize="11sp"
                        android:textColor="#64748B" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Current View Header Note -->
        <RelativeLayout
            android:id="@+id/viewHeaderLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F1F5F9"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/managerStatsLayout">

            <TextView
                android:id="@+id/tvCurrentViewTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Branch Inventory Overview"
                android:textStyle="bold"
                android:textColor="#475569"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddEmployee"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="+ Add"
                android:textColor="#E53E3E"
                android:textStyle="bold"
                android:textSize="12sp" />
        </RelativeLayout>

        <!-- Employee Search Bar (Dynamically Toggled) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/inputLayoutEmployeeSearch"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:hint="Search employees by name or email..."
            app:startIconDrawable="@android:drawable/ic_menu_search"
            app:boxStrokeColor="#E53E3E"
            app:hintTextColor="#E53E3E"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/viewHeaderLayout">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmployeeSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Main List Container -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/inputLayoutEmployeeSearch">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvManagerParcels"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_active_parcel" />
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <!-- Dynamic Settings / My Account Form Container -->
        <androidx.core.widget.NestedScrollView
            android:id="@+id/settingsFormContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:visibility="gone"
            android:padding="16dp"
            android:fillViewport="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@id/inputLayoutEmployeeSearch">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="#E2E8F0">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edit Profile"
                        android:textColor="#1E293B"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="4dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Update your branch manager profile natively"
                        android:textColor="#64748B"
                        android:textSize="13sp"
                        android:layout_marginBottom="24dp" />

                    <!-- First Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="First Name"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="#E53E3E"
                        app:hintTextColor="#E53E3E">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMgrFname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Last Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Last Name"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="#E53E3E"
                        app:hintTextColor="#E53E3E">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMgrLname"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email Address"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="#E53E3E"
                        app:hintTextColor="#E53E3E">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMgrEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Phone -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Contact Number"
                        android:layout_marginBottom="16dp"
                        app:boxStrokeColor="#E53E3E"
                        app:hintTextColor="#E53E3E">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMgrPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Change Password"
                        android:layout_marginBottom="24dp"
                        app:boxStrokeColor="#E53E3E"
                        app:hintTextColor="#E53E3E"
                        app:passwordToggleEnabled="true">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etMgrPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Save Profile Action Button -->
                    <Button
                        android:id="@+id/btnSaveProfile"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:backgroundTint="#E53E3E"
                        android:text="Save Profile Changes"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:cornerRadius="16dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </androidx.core.widget.NestedScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- RIGHT-SLIDING NAVIGATION PANEL DRAWER -->
    <LinearLayout
        android:id="@+id/rightDrawer"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:elevation="16dp">

        <!-- Drawer Header Banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="#E53E3E"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="bottom">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/spx_express"
                    android:padding="6dp"
                    android:scaleType="centerInside" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvDrawerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Branch Manager"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvDrawerEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="manager@spx.com"
                android:textColor="#FFCDCD"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Navigation Menu Item Rows -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Item 1: Overview -->
            <TextView
                android:id="@+id/navOverview"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="📦 Overview"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

            <!-- Item 2: Employees / Roster -->
            <TextView
                android:id="@+id/navEmployees"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="👥 Employees"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

            <!-- Item 3: Verify Cash -->
            <TextView
                android:id="@+id/navVerifyCash"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="💰 Verify Cash"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

            <!-- Item 4: Branch Log -->
            <TextView
                android:id="@+id/navBranchLog"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="📋 Branch Log"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

            <!-- Item 5: Edit Profile / Station Info -->
            <TextView
                android:id="@+id/navEditProfile"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:text="⚙️ Edit Profile"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"
                android:layout_marginBottom="8dp" />

        </LinearLayout>

        <!-- Divider & Logout Bottom Actions -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0" />

        <Button
            android:id="@+id/btnDrawerSignOut"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:text="Sign Out Manager"
            android:textColor="#E53E3E"
            app:strokeColor="#E53E3E"
            app:cornerRadius="12dp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
