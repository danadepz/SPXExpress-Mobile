<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingEnd="16dp">

    <!-- Vertical Timeline Line (Top Portion) -->
    <View
        android:id="@+id/timelineLineTop"
        android:layout_width="2dp"
        android:layout_height="24dp"
        android:background="#E2E8F0"
        app:layout_constraintEnd_toEndOf="@id/timelineDot"
        app:layout_constraintStart_toStartOf="@id/timelineDot"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Circle Milestone Indicator -->
    <View
        android:id="@+id/timelineDot"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="24dp"
        android:background="@drawable/circle_milestone_bg"
        android:backgroundTint="#EE4D2D"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/timelineLineTop" />

    <!-- Vertical Timeline Line (Bottom Portion) -->
    <View
        android:id="@+id/timelineLineBottom"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="#E2E8F0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/timelineDot"
        app:layout_constraintStart_toStartOf="@id/timelineDot"
        app:layout_constraintTop_toBottomOf="@id/timelineDot" />

    <!-- Dynamic Material Card for Logistics Info -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="#F1F5F9"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/timelineDot"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvStatusTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="#1E293B"
                tools:text="Received at Branch" />

            <TextView
                android:id="@+id/tvLocationNote"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="12sp"
                android:textColor="#64748B"
                tools:text="Verified and accepted at counter" />

            <TextView
                android:id="@+id/tvTimestamp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="10sp"
                android:textColor="#94A3B8"
                tools:text="2026-05-20 18:24:55" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</androidx.constraintlayout.widget.ConstraintLayout>
