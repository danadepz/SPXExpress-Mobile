<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#FDE68A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Row: Tracking + Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvRemitTracking"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPX-000000000"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#1E293B" />

                <TextView
                    android:id="@+id/tvRemitReceiver"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Receiver: —"
                    android:textSize="12sp"
                    android:textColor="#6B7280" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvRemitAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₱0.00 COD"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#059669"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:background="@drawable/bg_status_badge" />
        </LinearLayout>

        <!-- Status hint -->
        <TextView
            android:id="@+id/tvRemitStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Rider submitted remittance – awaiting your confirmation"
            android:textSize="11sp"
            android:textColor="#D97706"
            android:drawablePadding="4dp"
            android:layout_marginBottom="10dp" />

        <!-- Confirm Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmRemittance"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="✅  Confirm Cash Receipt"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:backgroundTint="#D97706"
            app:cornerRadius="12dp"
            app:elevation="2dp" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
