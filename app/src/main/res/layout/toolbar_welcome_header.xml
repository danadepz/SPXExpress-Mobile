<?xml version="1.0" encoding="utf-8"?>
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="0dp"
    android:paddingEnd="16dp"
    android:background="#FFFFFF">

    <!-- Profile Avatar Card (Elegant rounded card with shadow/border) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvToolbarAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="12dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:strokeColor="#E2E8F0">
        
        <ImageView
            android:id="@+id/ivToolbarAvatar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/spx_express"
            android:scaleType="centerInside"
            android:padding="6dp"
            android:contentDescription="Profile Avatar" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Mid Greeting and Name Area -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvToolbarGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome back,"
            android:textSize="11sp"
            android:fontFamily="@font/poppins"
            android:textColor="#94A3B8"
            android:letterSpacing="0.05" />

        <TextView
            android:id="@+id/tvToolbarName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="16sp"
            android:fontFamily="@font/poppins"
            android:textStyle="bold"
            android:textColor="#0F172A"
            android:ellipsize="end"
            android:maxLines="1" />
    </LinearLayout>

    <!-- Role Badge (Visually gorgeous rounded pill) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvToolbarBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#EFF6FF">
        
        <TextView
            android:id="@+id/tvToolbarRole"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Rider"
            android:textSize="10sp"
            android:textStyle="bold"
            android:fontFamily="@font/poppins"
            android:textColor="#3B82F6"
            android:letterSpacing="0.02" />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
