<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🤝 COD Remittance Confirmation"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#92400E"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Riders have submitted COD cash for these delivered parcels. Confirm receipt below."
        android:textSize="13sp"
        android:textColor="#78716C"
        android:layout_marginBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FDE68A"
        android:layout_marginBottom="12dp" />

    <!-- Remittances List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCodRemittances"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:nestedScrollingEnabled="true" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/llEmptyCodRemittances"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✅"
            android:textSize="36sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All COD remittances confirmed!"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No pending rider submissions at this branch."
            android:textSize="12sp"
            android:textColor="#9CA3AF"
            android:gravity="center" />
    </LinearLayout>

    <!-- Close Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseCodRemittances"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:text="Close"
        app:strokeColor="#D97706"
        android:textColor="#D97706"
        app:cornerRadius="12dp" />

</LinearLayout>
